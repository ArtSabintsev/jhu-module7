APP_BACKEND=aws
AWS_REGION=us-east-1

# SNS topics
INVENTORY_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:jhu-module7-inventory-updates
ALERT_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:jhu-module7-reorder-alerts

# SQS queues
INVENTORY_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/jhu-module7-inventory-worker
ALERT_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/jhu-module7-alert-notifier

# DynamoDB tables
INVENTORY_TABLE=jhu-module7-inventory
ALERT_TABLE=jhu-module7-reorder-alerts
NOTIFICATION_TABLE=jhu-module7-notification-audit

# ElastiCache Redis endpoint, reachable from EC2 instances in the VPC
REDIS_URL=redis://jhu-module7-cache.xxxxxx.0001.use1.cache.amazonaws.com:6379/0
CACHE_TTL_SECONDS=60

# API process
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
