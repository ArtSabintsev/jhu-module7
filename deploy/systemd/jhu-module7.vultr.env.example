APP_BACKEND=vultr
KAFKA_BOOTSTRAP_SERVERS=replace-with-kafka-host:replace-with-kafka-sasl-port
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=SCRAM-SHA-256
KAFKA_USERNAME=replace-with-kafka-user
KAFKA_PASSWORD=replace-with-kafka-password
KAFKA_INVENTORY_TOPIC=inventory-updates
KAFKA_ALERT_TOPIC=reorder-alerts
KAFKA_INVENTORY_GROUP=inventory-worker
KAFKA_ALERT_GROUP=alert-notifier
KAFKA_TOPIC_PARTITIONS=3
KAFKA_TOPIC_REPLICATION_FACTOR=1
POSTGRES_DSN="host=replace-with-postgres-host port=replace-with-postgres-port dbname=defaultdb user=replace-with-user password=replace-with-password sslmode=require"
REDIS_URL=rediss://:replace-with-password@replace-with-valkey-host:replace-with-valkey-port/0
CACHE_TTL_SECONDS=60
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
